# Gemini is always required for image generation (Nano Banana renders exercise
# visuals + the dashboard visual) even when OpenAI powers the reasoning below,
# since gpt-5.6-sol accepts image input only, not image output.
GEMINI_API_KEY=your_google_ai_studio_key

# Model ids default to gemini-3-flash-preview for intelligence and
# gemini-3-pro-image-preview (Nano Banana Pro) for image generation. Both are
# Gemini 3 preview models — if your key doesn't have preview access yet, or
# Google deprecates a preview id, override here with a model your account can
# access — no code change needed.
# GEMINI_TEXT_MODEL=gemini-3-flash-preview
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# OpenAI (gpt-5.6-sol) — set this to make OpenAI the reasoning/vision provider
# for health-report analysis, chat coaching, and the deep-agent crew. Image
# generation always stays on Gemini (see above).
OPENAI_API_KEY=your_openai_api_key
# OPENAI_TEXT_MODEL=gpt-5.6-sol

# Which provider powers reasoning/vision/chat: "openai" | "gemini". Defaults to
# openai automatically when OPENAI_API_KEY is set, otherwise falls back to gemini.
# AI_PROVIDER=openai

# Exa (exa.ai) web search — finds a real YouTube tutorial link for each routine
# exercise, plus blog/article references for the topics the model flags in
# browserResearchNeeded (shown in the report's "Further reading" section).
# Optional: video links and references are just skipped when unset.
# EXA_API_KEY=your_exa_api_key

# Deep-agent (dynamic subagent workflow) budget in ms before falling back to the
# primary vision report alone. Default 90000 assumes maxDuration=120 on
# /api/analyze (Vercel Pro+). On Hobby (60s function cap) lower this to ~35000.
# DEEP_AGENT_TIMEOUT_MS=90000

# Live web-evidence browsing (dynamic subagents call this). Off by default because
# Vercel's serverless functions are ephemeral: agent-browser needs a Chrome binary
# resolvable at runtime. When true, the server resolves Chrome via @sparticuz/chromium
# automatically on Vercel/AWS Lambda; locally, run `agent-browser install` first.
ENABLE_AGENT_BROWSER=false

# Optional overrides
# AGENT_BROWSER_BIN=agent-browser
# AGENT_BROWSER_EXECUTABLE_PATH=/path/to/chromium
